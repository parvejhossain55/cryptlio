# Application
APP_ENV=development
SERVER_PORT=8080

# JWT Authentication
JWT_SECRET=your-very-secure-secret-key-change-this-in-production
JWT_EXPIRY=24h

# Backend Services (microservices)
AUTH_SERVICE_URL=http://auth-service:8080
USER_SERVICE_URL=http://user-service:8080
WALLET_SERVICE_URL=http://wallet-service:8081
TRADE_ENGINE_URL=http://trade-engine:8082
KYC_SERVICE_URL=http://kyc-service:8083
NOTIFICATION_URL=http://notification:8084
DISPUTE_SERVICE_URL=http://dispute-service:8085
MERCHANT_SERVICE_URL=http://trade-engine:8082

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=1m

# CORS
CORS_ALLOWED_ORIGINS=*

# Logging (optional)
LOG_LEVEL=info
